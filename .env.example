# Copy to .env and fill in. Never commit the real .env.

# --- Database ---
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Postgres on the VPS), example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bdic?schema=public"

# --- Auth ---
# REQUIRED. Must be >= 32 chars and NOT a placeholder. The app refuses to sign
# tokens with a weak/known value (e.g. "change-me") and logs a CRITICAL warning
# at boot. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me"

# --- App ---
APP_URL="https://your-domain.com"

# --- WhatsApp automation ---
WHATSAPP_PROVIDER="mock"     # mock | metaCloud | wa
WHATSAPP_TOKEN=""            # Meta Cloud API permanent token
WHATSAPP_PHONE_ID=""         # Meta Cloud API phone number ID
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_DEFAULT_CC="20"

# Meta requires approved templates for proactive messages (see README -> WhatsApp setup)
WHATSAPP_USE_TEMPLATES="1"
WHATSAPP_TPL_RESERVED="bdic_booking_confirmed"
WHATSAPP_TPL_REMINDER="bdic_appointment_reminder"
WHATSAPP_TPL_QUEUE="bdic_queue_update"
WHATSAPP_TPL_TURN="bdic_your_turn"
WHATSAPP_LANG_EN="en"
WHATSAPP_LANG_AR="ar"

# --- Scheduler ---
REMINDER_LEAD_MIN="120"
QUEUE_LEAD_MIN="60"
SCHEDULER_ENABLED="1"

# --- Patient file uploads ---
UPLOADS_DIR="./private-uploads"

# --- SEO / Analytics (Phase 2) ---
# Public site URL (used for canonical, sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
# Google Analytics 4 (leave empty to disable)
NEXT_PUBLIC_GA_ID=""
# Meta (Facebook) Pixel (leave empty to disable)
NEXT_PUBLIC_FB_PIXEL_ID=""

# --- WhatsApp booking agent (inbound) ---
# Token YOU choose; enter the same value in the Meta webhook setup
WHATSAPP_VERIFY_TOKEN=""
# Meta App Secret � enables webhook signature verification (recommended)
WHATSAPP_APP_SECRET=""

# Dedicated clinic WhatsApp bot number (digits only, no +) � shown on the site's Confirm-on-WhatsApp button
NEXT_PUBLIC_CLINIC_WHATSAPP=""

# --- WhatsApp Web worker (whatsapp-web.js, no Meta/card) ---
# Shared secret between the site and worker/whatsapp-web.mjs (set the SAME value in both).
WA_AGENT_SECRET=""
# Where the worker reaches the site (worker only):
APP_BASE_URL="http://localhost:3000"

# --- WhatsApp simulate endpoint ---
# Dev/testing only. With a non-"mock" provider the /api/whatsapp/simulate route is
# 404 unless this is set to 1 (and then it requires an authenticated session).
# NEVER set this to 1 in production. See docs/SECURITY.md.
WA_SIMULATE_ENABLED=""
