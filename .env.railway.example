# ------------------------------------------------------------------------------
# Railway variables for the clinic site (web + doctor dashboard).
# Copy each of these into your Railway service → Variables. They apply at BOTH
# build time and runtime. Do NOT commit real secrets — this file is a template.
#
# WHICH CLINIC: change the two slugs below to pick the clinic this service
# serves ("badawi" or "ibrahim"). It is baked into the build, so after changing
# it you must REDEPLOY.
# ------------------------------------------------------------------------------

# --- Which clinic this deployment serves (baked into the build) ---
# MUST be set before the build runs so the branding compiles in.
# badawi = Badawi Dental Implant Center · ibrahim = THE BOSS Dental Clinic
NEXT_PUBLIC_CLINIC=badawi
CLINIC=badawi

# --- Port the app listens on ---
# Set this to MATCH the target port on your Railway domain (you chose 8080).
# The app binds to $PORT; keeping app port == domain target == healthcheck port
# is what makes the healthcheck pass.
PORT=8080

# --- Database: SQLite file on the Railway Volume mounted at /data ---
# Create a Volume on the service and mount it at /data, then use this path so the
# database survives redeploys. Use a per-clinic file name.
DATABASE_URL=file:/data/badawi.db

# --- Patient file uploads (x-rays, photos) also live on the Volume ---
UPLOADS_DIR=/data/uploads

# --- Auth: sign in to the dashboard. Generate a long random string. ---
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
AUTH_SECRET=replace-with-a-long-random-string

# --- Seed the first dashboard login (created on first boot; change after!) ---
SEED_DOCTOR_EMAIL=doctor@bdic.clinic
SEED_DOCTOR_PASSWORD=change-this-strong-password
SEED_DOCTOR_NAME=Dr. Badawi

# --- Public URL (set to the domain Railway assigns, then your custom domain) ---
# Fill these in AFTER the first deploy gives you a *.up.railway.app URL.
APP_URL=https://REPLACE.up.railway.app
NEXT_PUBLIC_SITE_URL=https://REPLACE.up.railway.app

# --- WhatsApp booking bot is NOT part of this deploy ---
# "mock" just logs messages to the DB; wa.me confirm links still work. Leaving the
# bot off keeps the web service light (no Chromium). Turn it on later on a VPS.
WHATSAPP_PROVIDER=mock
WHATSAPP_DEFAULT_CC=20

# Keep the in-process reminder scheduler off unless you wire up sending.
SCHEDULER_ENABLED=0
