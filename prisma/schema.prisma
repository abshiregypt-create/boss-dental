// BDIC backend schema. Postgres in every environment (Railway provisions the
// database; DATABASE_URL points at it). Run `prisma migrate deploy` on release.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Clinic staff who can sign in to the dashboard.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("doctor") // doctor | admin | staff
  createdAt    DateTime @default(now())
}

/// A person who has booked at least once.
model Patient {
  id           String            @id @default(cuid())
  name         String
  phone        String
  email        String?
  gender       String? // male | female
  source       String            @default("booking") // booking | manual
  notes        String?
  medical      Json? // { bloodType, allergies, conditions, medications, notes }
  createdAt    DateTime          @default(now())
  appointments Appointment[]
  treatments   TreatmentRecord[]
  payments     Payment[]

  @@index([phone])
}

/// The clinic's catalog of operations/procedures (خلع، تركيب، حشو…), each with a
/// default price. The doctor manages this list; treatment records snapshot the
/// name + price at the time they're recorded so later edits don't rewrite history.
model Procedure {
  id        String   @id @default(cuid())
  nameEn    String
  nameAr    String
  price     Float    @default(0) // patient/charged price in EGP (net + profit)
  cost      Float? // optional net cost (صافي): materials/lab, before profit — for clinic-profit precision
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  treatments TreatmentRecord[]

  @@index([active, sortOrder])
}

/// A procedure actually performed for a patient in a visit. Price is the amount
/// charged (snapshot). Balance owed = sum(price) − sum(linked/patient payments).
model TreatmentRecord {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedureId   String? // catalog link (null if custom or catalog entry was deleted)
  procedure     Procedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  appointmentId String? // optional link to the visit it happened in
  nameEn        String
  nameAr        String
  basePrice     Float?    // list/catalog price before any discount (for display)
  discountPct   Float     @default(0) // percentage discount applied (0–100)
  price         Float     @default(0) // net amount charged after discount (EGP) — the doctor commission base
  cost          Float?    // snapshot net cost (materials/lab) at time of operation, for clinic-profit precision
  notes         String?
  performedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments Payment[]
  doctors  TreatmentDoctor[]

  @@index([patientId, performedAt])
}

/// A payment received from a patient. May be tied to a specific treatment (an
/// operation's part/full payment) or be a general account payment.
model Payment {
  id                String           @id @default(cuid())
  patientId         String
  patient           Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatmentRecordId String?
  treatmentRecord   TreatmentRecord? @relation(fields: [treatmentRecordId], references: [id], onDelete: SetNull)
  amount            Float            @default(0) // EGP
  method            String           @default("cash") // cash | card | insurance | transfer
  note              String?
  paidAt            DateTime         @default(now())
  createdAt         DateTime         @default(now())

  @@index([patientId, paidAt])
}

/// A booking. Drives the whole confirm -> WhatsApp -> queue flow.
model Appointment {
  id             String    @id @default(cuid())
  code           String    @unique // short public code used in /track/[code]
  patientName    String
  phone          String
  serviceId      String
  serviceLabelEn String
  serviceLabelAr String
  scheduledAt    DateTime // absolute appointment start
  durationMin    Int       @default(30)
  status         String    @default("pending") // pending | confirmed | declined | completed | cancelled
  complaint      String?
  offerTitle     String?
  notes          String?
  lang           String    @default("en") // patient's preferred language for messages
  waChatId       String? // whatsapp-web.js chat id (msg.from) for reliable replies

  confirmedAt    DateTime?
  reminderSentAt DateTime?
  queueOpenedAt  DateTime?
  turnSentAt     DateTime?
  completedAt    DateTime?
  followupSentAt DateTime? // post-session follow-up ("how are you feeling?") sent once

  patientId String?
  patient   Patient?  @relation(fields: [patientId], references: [id])
  doctorId  String? // optional: which doctor this visit is booked with
  doctor    Doctor?   @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([phone])
  @@index([doctorId])
}

/// A WhatsApp message tied to an appointment (audit log + idempotency).
model Message {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  phone         String
  kind          String // reserved | reminder | queue | turn | custom
  body          String
  provider      String      @default("mock") // mock | metaCloud | wa.me
  status        String      @default("queued") // queued | sent | delivered | failed
  waLink        String?
  error         String?
  createdAt     DateTime    @default(now())
  sentAt        DateTime?

  @@index([appointmentId, kind])
}

/// Simple key/value config (clinic hours, feature flags, etc.).
model Setting {
  key       String   @id
  value     String // JSON
  updatedAt DateTime @updatedAt
}

/// In-progress WhatsApp booking conversation, one row per chat (phone number).
/// `state` is the step in the flow; `draft` is the JSON being collected.
model WaConversation {
  id        String   @id @default(cuid())
  phone     String   @unique
  chatId    String? // the whatsapp-web.js chat id (msg.from) used to reply reliably
  state     String   @default("idle") // idle|day|slot|why|name|followup
  draft     String? // JSON: { dateISO, dateLabel, slot, timeLabel, reason, patientName }
  lang      String   @default("ar") // ar | en
  agentPausedUntil DateTime? // while in the future, the booking bot stays silent (manual chat)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([updatedAt])
}

/// Outgoing WhatsApp messages the SERVER initiates (e.g. the doctor-confirm
/// notification). The whatsapp-web.js worker polls this, sends them, and marks
/// them sent — so server-side events reach the patient over the linked number.
model WaOutbox {
  id        String   @id @default(cuid())
  phone     String
  chatId    String? // exact whatsapp-web.js chat id to reply to (preferred over phone)
  body      String
  status    String   @default("queued") // queued | sent | failed
  createdAt DateTime @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

/// A file attached to a patient (x-ray, intra-oral photo, scanned document).
/// The binary lives on disk under the uploads dir; only metadata is in the DB.
model PatientFile {
  id          String   @id @default(cuid())
  patientKey  String // local patient id (e.g. "pt-ahmed") or Patient.id
  patientName String?
  category    String   @default("xray") // xray | photo | document | medical
  title       String?
  fileName    String
  mimeType    String
  size        Int
  storagePath String // path on disk, relative to the uploads dir
  createdAt   DateTime @default(now())

  @@index([patientKey, createdAt])
}

/// A WhatsApp chat message to/from a patient — the doctor's "Client Messages"
/// inbox. Logs every inbound patient message and every outbound message the
/// clinic sends (post-session follow-ups + the doctor's manual replies), keyed
/// by phone so they group into one conversation thread.
model ChatMessage {
  id        String    @id @default(cuid())
  phone     String // normalized digits (the conversation key)
  chatId    String? // exact whatsapp-web.js chat id used to reply (handles @lid)
  direction String // "in" (from patient) | "out" (from clinic)
  body      String
  kind      String    @default("chat") // chat | followup | reply | manual
  readAt    DateTime? // when the doctor read an inbound message (null = unread)
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([direction, readAt])
}

/// A doctor/practitioner at the clinic who can be assigned to operations. Managed
/// by the owner (separate from the login `User`). `commissionPct` is the default
/// percentage of the patient/charged price this doctor earns per operation; the
/// clinic keeps the remainder. Editable per-operation at record time.
model Doctor {
  id            String   @id @default(cuid())
  nameEn        String
  nameAr        String
  phone         String?
  email         String?
  specialtyEn   String?
  specialtyAr   String?
  photoUrl      String? // /uploads path or data URL for the profile picture
  commissionPct Float    @default(0) // default % of the charged price (0–100)
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  treatments TreatmentDoctor[]
  appointments Appointment[]
  payouts    DoctorPayout[]

  @@index([active, sortOrder])
}

/// Join row: a doctor assigned to a treatment/operation, with the commission/// percentage and earned amount SNAPSHOT at the time it was recorded (so later
/// profile edits don't rewrite history). More than one doctor can share one
/// operation; the clinic's share = price − Σ(amount).
model TreatmentDoctor {
  id                String          @id @default(cuid())
  treatmentRecordId String
  treatmentRecord   TreatmentRecord @relation(fields: [treatmentRecordId], references: [id], onDelete: Cascade)
  doctorId          String
  doctor            Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  commissionPct     Float           @default(0) // snapshot % of the charged price for this operation
  amount            Float           @default(0) // snapshot earned amount (pct% × price), EGP
  createdAt         DateTime        @default(now())

  @@unique([treatmentRecordId, doctorId])
  @@index([doctorId])
}

/// A payout PAID TO a doctor against their accrued commission earnings. Earnings
/// accrue per operation (TreatmentDoctor.amount); payouts draw them down. The
/// doctor's outstanding balance = Σ(earnings) − Σ(payouts).
model DoctorPayout {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  amount    Float    @default(0) // EGP paid to the doctor
  method    String   @default("cash") // cash | card | transfer | other
  reference String? // cheque/transfer reference number
  note      String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([doctorId, paidAt])
}

/// A recurring monthly clinic expense (rent, electricity, or a custom type) that
/// reduces the clinic's net profit on the Revenue page. `amount` is the default
/// monthly value; a specific month can be overridden via ClinicExpenseOverride.
model ClinicExpense {
  id        String   @id @default(cuid())
  labelEn   String
  labelAr   String
  kind      String   @default("custom") // rent | electricity | custom
  amount    Float    @default(0) // default recurring monthly amount (EGP)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  overrides ClinicExpenseOverride[]
}

/// Overrides the amount of a recurring ClinicExpense for one specific month
/// (monthKey = "YYYY-MM"). Absent months fall back to ClinicExpense.amount.
model ClinicExpenseOverride {
  id        String        @id @default(cuid())
  expenseId String
  expense   ClinicExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  monthKey  String // "YYYY-MM"
  amount    Float         @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([expenseId, monthKey])
}
